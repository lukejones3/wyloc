{
  "id": "aws.secret_access_key_contextual",
  "displayName": "AWS secret access key (contextual)",
  "tier": "tier_3",
  "type": "aws_secret_key",
  "confidence": "high",
  "blockEligible": true,
  "reason": "Looks like an AWS secret access key (40-char key with AWS context nearby).",
  "regex": { "source": "(?<![A-Za-z0-9/+])[A-Za-z0-9/+]{40}(?![A-Za-z0-9/+=])" },
  "requiredContext": [
    "aws",
    "amazon",
    "secret access key",
    "secret_access_key",
    "secretaccesskey"
  ],
  "contextRegex": { "source": "\\b(?:AKIA|ASIA|ABIA|ACCA)[A-Z0-9]{16}\\b" },
  "entropyThreshold": 3.5,
  "fixtures": {
    "positive": [
      "aws creds:\nAKIA2RZ4QF7KJ9XW1MTL\nkR9wPzX2mB5nQ8vL3cF6dG1hY4uZ7aE0iO2sT5xW",
      "export AWS_SECRET_KEY=\"kR9wPzX2mB5nQ8vL3cF6dG1hY4uZ7aE0iO2sT5xW\""
    ],
    "negative": [
      "kR9wPzX2mB5nQ8vL3cF6dG1hY4uZ7aE0iO2sT5xW",
      "the aws fingerprint 9f86d081884c7d659a2feaa0c55ad015a3bf4f1b digest"
    ]
  }
}
